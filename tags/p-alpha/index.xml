width="760"
height="259"
loading="lazy" data-zoomable /&gt;&lt;/div&gt;
&lt;/div&gt;&lt;/figure&gt;
&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;图 a, b：Jutzi et al. 2009 论文中的实验结果和基准模拟结果。&lt;/li&gt;
&lt;li&gt;图 c：GASPHiA 的模拟结果。&lt;/li&gt;
&lt;/ul&gt;
&lt;blockquote class="border-l-4 border-neutral-300 dark:border-neutral-600 pl-4 italic text-neutral-600 dark:text-neutral-400 my-6"&gt;
&lt;p&gt;可以看到，GASPHiA 输出的物理形态与原始实验及基准论文高度吻合。&lt;/p&gt;
&lt;/blockquote&gt;
&lt;p&gt;
&lt;figure &gt;
&lt;div class="flex justify-center "&gt;
&lt;div class="w-full" &gt;
&lt;img alt="碎片质量累积分布曲线对比"
srcset="https://yekq.top/blog/gasphia/p-alpha-porosity-model/porous_cm_hu_9b57da9843871f6f.webp 320w, https://yekq.top/blog/gasphia/p-alpha-porosity-model/porous_cm_hu_ff5fe8c5b9c1fad.webp 480w, https://yekq.top/blog/gasphia/p-alpha-porosity-model/porous_cm_hu_3a6c6ccf08cdc862.webp 760w"
sizes="(max-width: 480px) 100vw, (max-width: 768px) 90vw, (max-width: 1024px) 80vw, 760px"
